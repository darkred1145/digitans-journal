{
  "manifest_version": 3,
  "name": "Digitan's Journal",
  "version": "1.0.0",
  "description": "Shows what you're browsing as Discord Rich Presence",
  "permissions": [
    "nativeMessaging",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "clear-activity": {
      "suggested_key": { "default": "Alt+C" },
      "description": "Clear current activity"
    }
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' 'unsafe-inline'"
  },
  "content_scripts": [
    {
      "matches": ["https://nhentai.net/*"],
      "js": ["content-scripts/nhentai.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gametora.com/umamusume*"],
      "js": ["content-scripts/gametora.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://raggooneropen.web.app/*"],
      "js": ["content-scripts/raggooner.js"],
      "run_at": "document_idle"
    }
  ]
}
